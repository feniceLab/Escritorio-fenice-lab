# OpenClaw Gateway. Use the same token configured in OpenClaw.
OPENCLAW_TOKEN=
OPENCLAW_BASE_URL=http://127.0.0.1:18789

# Optional shared group where agents can talk to each other.
TELEGRAM_AGENTS_GROUP_ID=

# One bot token per agent. Leave blank until the bot exists.
TELEGRAM_LORD_STARKEN_TOKEN=
TELEGRAM_LURDINHA_TOKEN=
TELEGRAM_JOSY_TOKEN=
TELEGRAM_SNEIDER_TOKEN=
TELEGRAM_NINA_TOKEN=
TELEGRAM_RAVI_TOKEN=
TELEGRAM_MARIA_TOKEN=
TELEGRAM_JOAO_TOKEN=
TELEGRAM_ZEZIN_TOKEN=
TELEGRAM_TEO_TOKEN=
TELEGRAM_GAIA_TOKEN=
TELEGRAM_MAYA_TOKEN=

# Runtime paths.
AGENT_TELEGRAM_MANIFEST=/var/www/starken-os/integrations/agent-telegram/agents.manifest.json
AGENT_TELEGRAM_MEMORY_ROOT=/var/www/starken-os/agent-memory
AGENT_TELEGRAM_STATE_DIR=/var/www/starken-os/.runtime/agent-telegram

# Behavior.
AGENT_TELEGRAM_POLL_MS=1200
AGENT_TELEGRAM_MEMORY_IMPORTANCE_MIN=0.62
AGENT_TELEGRAM_MAX_RESPONSE_CHARS=3500
