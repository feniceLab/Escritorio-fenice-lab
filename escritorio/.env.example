# .env.example — copie para .env.local e preencha os valores
# ============================================================
# BANCO DE DADOS (Supabase — usar direct URL, não pooler)
DATABASE_URL=postgresql://postgres:SENHA@db.ID.supabase.co:5432/postgres
DATABASE_DIRECT_URL=postgresql://postgres:SENHA@db.ID.supabase.co:5432/postgres
DB_TYPE=postgresql

# AUTENTICAÇÃO
JWT_SECRET=gerar_com_openssl_rand_hex_32

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_URL=https://ID.supabase.co/storage/v1
SUPABASE_STORAGE_BUCKET=office-media

# META / FACEBOOK
META_ACCESS_TOKEN=EAAr...
FB_ACCESS_TOKEN=EAAr...
META_MCP_TOKEN=EAAr...

# TELEGRAM BOTS
TELEGRAM_OPERATIONAL_GROUP_ID=-100...
TELEGRAM_AGENTS_GROUP_ID=-100...
TELEGRAM_MEETING_GROUP_ID=-100...
TELEGRAM_MEETING_CHANNEL_ID=uuid...
TELEGRAM_EUGENE_SCHWARTZ_BOT_TOKEN=...
TELEGRAM_FRANK_KERN_BOT_TOKEN=...
TELEGRAM_NASSIM_TALEB_BOT_TOKEN=...
TELEGRAM_PEDRO_SOBRAL_BOT_TOKEN=...
TELEGRAM_PRISCILA_ZILLO_BOT_TOKEN=...
TELEGRAM_SAM_ALTMAN_BOT_TOKEN=...
TELEGRAM_STEVE_JOBS_BOT_TOKEN=...
TELEGRAM_TONY_ROBBINS_BOT_TOKEN=...

# OPENCLAW / AI
OPENCLAW_TOKEN=...
OPENCLAW_MODEL=openai-codex/gpt-5.4
GROQ_API_KEY=gsk_...
ELEVENLABS_API_KEY=sk_...

# MODO EMBEDDED (opcional)
FENIX_EMBEDDED=false
COOKIE_SECURE=true

# DOCKER IMAGES (opcional)
DESKRPG_IMAGE=dandacompany/deskrpg:latest
OPENCLAW_IMAGE=deskrpg-openclaw:latest
